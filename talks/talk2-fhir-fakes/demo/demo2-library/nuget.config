<?xml version="1.0" encoding="utf-8"?>
<!--
  TEMPORARY: points this demo at a locally-built Ignixa feed so it can use the
  edge-case / seeding API from PR #283. That PR is merged to main but not yet
  published to NuGet (release is a manual workflow). Delete this file and reset the
  package versions to a published one (>= 0.5.3) once a release is cut.
-->
<configuration>
  <packageSources>
    <add key="ignixa-local-branch" value="C:\Src\ignixa-fhir\.local-nupkg" />
  </packageSources>
</configuration>
